{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "code-indexer": {
      "type": "local",
      "command": ["docker", "compose", "run", "-T", "--quiet-pull", "--rm", "indexer"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    }
  }
}
