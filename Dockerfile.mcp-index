FROM python:3.11-slim-bookworm

# Install system dependencies
RUN apt-get update && apt-get install -y \
    universal-ctags \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install the MCP server and Rust tree-sitter
RUN pip install code-index-mcp tree-sitter-rust

# Copy patch script and apply it
COPY patch_indexer.py /tmp/patch_indexer.py
RUN python3 /tmp/patch_indexer.py && rm /tmp/patch_indexer.py

WORKDIR /project
